# ──────────────────────────────────────────────────────────────
# Voila Luxury Skincare — environment variables
# Copy to `.env.local` and fill in. NEVER commit real secrets.
# ──────────────────────────────────────────────────────────────

# Canonical public site URL (used for SEO, sitemap, OG tags)
NEXT_PUBLIC_SITE_URL=https://voilaaesthetics.com

# Google Analytics 4 measurement ID (e.g. G-XXXXXXXXXX). Leave blank to disable.
NEXT_PUBLIC_GA_ID=

# ── Lead email delivery (optional) ──
# If RESEND_API_KEY is set, the contact form emails leads via Resend.
# If unset, the form still validates & succeeds, and the UI nudges to WhatsApp.
RESEND_API_KEY=
LEAD_NOTIFY_EMAIL=hello@voilaaesthetics.com
LEAD_FROM_EMAIL=onboarding@resend.dev
